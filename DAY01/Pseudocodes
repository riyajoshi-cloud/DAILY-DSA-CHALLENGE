3. Multiplication Table ( 1 to 10 )
Start
Input n 
Set i = 1
while i<=10 DO
   result = n * i
   Print n, "x", i, "=", result
   i+=1
End while
Stop

4. HCF AND LCM 
Start
Input a
Input b

IF a > b THEN
    num = a
    den = b
ELSE
    num = b
    den = a
END IF

rem = num % den

WHILE rem != 0 DO
    num = den
    den = rem
    rem = num % den
END WHILE

HCF = den
LCM = (a * b) / HCF

Print HCF, LCM
Stop


5. SUM UNTIL 'X'
Start 
Set sum = 0
Input n
WHILE n!= X DO
   sum = sum + n
   Input n
END WHILE
Print sum
Stop
